{
  "name": "vibo-backend",
  "version": "1.0.0",
  "description": "Backend for the Vibo",
  "license": "ISC",
  "author": "Vibo",
  "type": "commonjs",
  "main": "main.ts",
  "scripts": {
    "create:module": "node scripts/createModule.ts",
    "migration:create": "tsx scripts/db/createMigration.ts",
    "migrate": "dotenv -e .env.dev -- tsx core/database/migrate.ts",
    "migrate:prod": "dotenv -e .env.production -- tsx core/database/migrate.ts",
    "seed": "dotenv -e .env.dev -- tsx scripts/db/runSeeds.ts",
    "dev": "dotenv -e .env.dev -- tsx watch main.ts",
    "build": "tsc",
    "start": "node dist/main.js"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.3",
    "pg": "^8.20.0",
    "resend": "^6.9.4"
  }
}
