# Email (Resend) — verify domain + set a real FROM for production
RESEND_API_KEY =
# From header, e.g. VIBO <hello@hellovibo.in> (must be allowed in Resend)
EMAIL_FROM = 
# Replies go here (shown in client; helps deliverability)
EMAIL_REPLY_TO =
SUPPORT_EMAIL = 
# Links inside templates (waitlist referral URL base)
PUBLIC_WEB_URL = 
APP_STORE_URL =
PLAY_STORE_URL =

# You invent this value (long random string). Same value must be sent as HTTP header:
#   x-internal-key: <INTERNAL_API_KEY>
# Used for internal routes e.g. POST /v0/api/web/email/send-batch, /email/notify-city
INTERNAL_API_KEY =

# FCM (optional until set) — use ONE of:
# Path to the Firebase Admin private key JSON (download from Firebase Console → Project settings → Service accounts).
# FIREBASE_SERVICE_ACCOUNT_PATH=./google-service-account.json
# Or paste the entire JSON as one line (hosted secrets) — not a path:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: push when paid hosting drops Sparks from above this value to at/below (default 50).
# SPARKS_LOW_PUSH_THRESHOLD=50